# Maintainer: Voice Input
pkgname=voice-input
pkgver=0.2.0
pkgrel=1
pkgdesc="Voice input for KDE Plasma 6 (Wayland)"
arch=('any')
license=('MIT')
depends=(
    'python'
    'python-pyqt6'
    'python-sounddevice'
    'qt6-wayland'
    'wl-clipboard'
    'ydotool'
    'libnotify'
    'python-evdev'
)
optdepends=(
    'python-keyring: store API keys in KDE Wallet'
)
makedepends=('python-build' 'python-installer' 'python-setuptools')
source=()

package() {
    cd "$srcdir/.."

    # Install Python package (sherpa-onnx model downloaded on first run)
    python -m installer --destdir="$pkgdir" dist/*.whl

    # Desktop file
    install -Dm644 src/voice_input/resources/voice-input.desktop \
        "$pkgdir/usr/share/applications/voice-input.desktop"

    # systemd user unit
    install -Dm644 packaging/systemd/voice-input.service \
        "$pkgdir/usr/lib/systemd/user/voice-input.service"
}
